NODE_ENV=test
SKIP_ENV_VALIDATION=1
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-not-a-real-key

# Points at docker-compose.test.yml's alternate ports so a test run can
# never truncate the dev database.
DATABASE_URL=postgresql://playerz:playerz@localhost:55432/playerz_test
REDIS_URL=redis://localhost:63790

STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_test_dummy
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_dummy
SMTP_URL=smtp://localhost:1025

MEILISEARCH_HOST=http://localhost:7701
MEILISEARCH_MASTER_KEY=test-master-key # pragma: allowlist secret

CENTRIFUGO_API_URL=http://localhost:8001/api
CENTRIFUGO_API_KEY=test-api-key # pragma: allowlist secret
CENTRIFUGO_TOKEN_SECRET=test-token-secret # pragma: allowlist secret
