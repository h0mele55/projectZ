# Epic C.2 — secret-detection pattern source of truth.
#
# Both the local pre-commit scanner (`scripts/detect-secrets.sh`) and
# the CI guardrail (`tests/guardrails/no-secrets.test.ts`) load this
# file at run time. Keeping a single text source means the local hook
# and CI cannot drift apart.
#
# Format
# ------
#   name | extended-PCRE regex
#
# - Blank lines and `# …` comment-only lines are ignored.
# - Both sides are trimmed of leading/trailing whitespace; the regex
#   itself is passed through verbatim, so `|` inside the regex is
#   fine — only the FIRST `|` separates name from regex.
# - PCRE extensions used by some patterns: `(?i)` for case-insensitive,
#   non-capturing groups for clarity. Tested against `grep -P`.
#
# Maintenance
# -----------
# When you add a pattern:
#   1. Pick a name that's actionable in a failure message.
#   2. Make the regex tight — prefer explicit issuer prefixes, length
#      lower-bounds, and surrounding boundaries to keep noise down.
#   3. Add a positive case AND a same-shape negative case to
#      `tests/unit/security/detect-secrets.test.ts`.
#   4. If the pattern catches something legitimate that lives in this
#      repo (a sample env, a test fixture, a scanner doc string), add
#      `# pragma: allowlist secret` inline OR move the fixture under
#      `tests/fixtures/secrets/` (auto-skipped).
#
# When you remove a pattern:
#   - Drop the line here AND the unit-test case it covers, and explain
#     in the PR description why the secret class is no longer in scope.

# ── AWS ────────────────────────────────────────────────────────────
AWS Access Key ID | (^|[^A-Z0-9])(AKIA|ASIA)[0-9A-Z]{16}([^A-Z0-9]|$)
AWS Secret Access Key (named assignment) | (?i)(aws(.{0,20})?(secret|access)(.{0,20})?key|secret(.{0,20})?access(.{0,20})?key)\s*[:=]\s*[\x27"][A-Za-z0-9/+=]{30,}[\x27"]

# ── GitHub ────────────────────────────────────────────────────────
GitHub Token | (^|[^A-Za-z0-9])gh[pousr]_[A-Za-z0-9]{30,}

# ── Slack ─────────────────────────────────────────────────────────
Slack Bot/User Token | (^|[^A-Za-z0-9])xox[abprs]-[A-Za-z0-9-]{10,}
Slack Webhook URL | https://hooks\.slack\.com/services/T[A-Z0-9]{8,}/B[A-Z0-9]{8,}/[A-Za-z0-9]{20,}

# ── AI providers ──────────────────────────────────────────────────
# OpenAI requires the explicit proj-/svcacct- prefix or the legacy
# infix shape so we don't double-fire on `sk-ant-…`.
#
# The legacy infix marker below is written as [T]3Blbk[F]J rather than
# the bare literal. The two are regex-equivalent (a one-char class
# matches that one char), but the bare literal makes THIS FILE look
# like an OpenAI key to GitHub's push protection, which rejects the
# push. Deviation from the byte-for-byte inflect-compliance copy is
# deliberate and confined to these two character classes.
Anthropic API Key | (^|[^A-Za-z0-9])sk-ant-[A-Za-z0-9_-]{40,}
OpenAI API Key | (^|[^A-Za-z0-9])sk-(proj|svcacct)-[A-Za-z0-9_-]{40,}|(^|[^A-Za-z0-9])sk-[A-Za-z0-9]{20}[T]3Blbk[F]J[A-Za-z0-9]{20}
Google API Key | (^|[^A-Za-z0-9])AIza[0-9A-Za-z_-]{35}

# ── Stripe ────────────────────────────────────────────────────────
Stripe Live Secret Key | (^|[^A-Za-z0-9])sk_live_[A-Za-z0-9]{24,}
Stripe Restricted Key | (^|[^A-Za-z0-9])rk_live_[A-Za-z0-9]{24,}

# ── JWT ───────────────────────────────────────────────────────────
# In-source quoted literal only — long enough to plausibly be a real
# token, three base64url segments separated by `.`.
JWT (in-source literal) | [\x27"]eyJ[A-Za-z0-9_-]{8,}\.eyJ[A-Za-z0-9_-]{8,}\.[A-Za-z0-9_-]{8,}[\x27"]

# ── PEM keys ──────────────────────────────────────────────────────
PEM Private Key | -----BEGIN ((RSA|DSA|EC|OPENSSH|PGP) )?PRIVATE KEY-----

# ── npm ───────────────────────────────────────────────────────────
NPM Token | (^|[^A-Za-z0-9])npm_[A-Za-z0-9]{36}

# ── Generic credential-shaped assignments ─────────────────────────
# Match `password = "…"`, `api_key: "…"`, etc., where the right-hand
# side is long enough to plausibly be a real secret. 16+ chars with
# mixed alphanumerics. Last entry — highest false-positive surface,
# so prefer the specific issuer patterns above when adding new ones.
Hardcoded Password Assignment | (?i)(password|passwd|pwd|secret|api[_-]?key|access[_-]?token|auth[_-]?token|client[_-]?secret)\s*[:=]\s*[\x27"][^\x27"\s]{16,}[\x27"]
