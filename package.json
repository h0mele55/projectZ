{
  "name": "playerz-bg",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest --selectProjects unit rendered --passWithNoTests",
    "test:int": "dotenv -e .env.test -- jest --selectProjects integration --runInBand --passWithNoTests",
    "test:guardrails": "jest --selectProjects guardrails --passWithNoTests",
    "test:ci": "jest --ci --runInBand --reporters=default --reporters=jest-junit --passWithNoTests",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test --pass-with-no-tests",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "db:seed": "tsx scripts/seed.ts",
    "worker": "tsx scripts/worker.ts",
    "prepare": "husky"
  },
