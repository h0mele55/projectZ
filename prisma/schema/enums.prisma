// ── Identity & tenancy ──────────────────────────────────────────────

enum Role {
  OWNER
  MANAGER
  COACH
  STAFF
  PLAYER
}

enum MembershipStatus {
  INVITED
  ACTIVE
  SUSPENDED
  /// The subscription lapsed (a failed renewal, a cancellation). Distinct from
  /// SUSPENDED, which is a deliberate act by the club — a member whose card
  /// expired must not be shown the same message as one who was suspended.
  EXPIRED
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  CLOSED
}

enum PlanTier {
  FREE
  CLUB
  PRO
}

// ── Sport domain ────────────────────────────────────────────────────

enum SportType {
  // ── Racket ────────────────────────────────────────────────────────
  TENNIS
  PADEL
  BADMINTON
  TABLE_TENNIS
  BEACH_TENNIS
  PICKLEBALL

  // ── Team ball ─────────────────────────────────────────────────────
  FOOTBALL5
  FOOTBALL
  BASKETBALL
  VOLLEYBALL
  BEACH_VOLLEYBALL
  HANDBALL

  // ── Board ─────────────────────────────────────────────────────────
  CHESS

  // ── Esport ────────────────────────────────────────────────────────
  ESPORTS

  // ── Endurance ─────────────────────────────────────────────────────
  RUNNING
  CYCLING
}

/// What kind of thing is actually being reserved.
///
/// The MVP called everything a Court, which stopped being true the moment a
/// chess table, an e-sports lobby and a running route had to be bookable.
enum ResourceType {
  COURT
  FIELD
  TABLE
  BOARD_TABLE
  LOBBY
  ROUTE
}

enum CourtSurface {
  CLAY
  HARD
  GRASS
  ARTIFICIAL_GRASS
  CARPET
  WOOD
  CONCRETE
}

enum SessionType {
  PRIVATE_BOOKING
  OPEN_PLAY
  COACHING
  TOURNAMENT
}

enum SkillLevel {
  BEGINNER
  IMPROVER
  INTERMEDIATE
  ADVANCED
  COMPETITIVE
}

// ── Booking & money ─────────────────────────────────────────────────
// P05 wires these to the Booking / Payment models. Declared here so the
// whole enum surface lands in one migration rather than dribbling across
// two.

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum PaymentStatus {
  REQUIRES_ACTION
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum Locale {
  bg
  en
}
