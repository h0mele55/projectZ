model OpenPlaySession {
  id         String  @id @default(cuid())
  tenantId   String
  resourceId String?

  hostUserId  String
  sport       SportType
  /// Denormalised from the registry so a family filter is one index hit, not
  /// a 16-way IN clause rebuilt on every query.
  sportFamily String    @default("RACKET")

  /// RESOURCE  — a court/table/lobby is reserved (the MVP model).
  /// MEETING_POINT — running and cycling: people agree to meet at a lat/lng.
  ///   There is nothing to reserve, so resourceId is null.
  locationMode    String   @default("RESOURCE")
  meetingPointLat Decimal? @db.Decimal(10, 7)
  meetingPointLng Decimal? @db.Decimal(10, 7)
  routeRef        String?

  startTs DateTime @db.Timestamptz(3)
  endTs   DateTime @db.Timestamptz(3)

  minSkillLevel   SkillLevel @default(BEGINNER)
  maxSkillLevel   SkillLevel @default(COMPETITIVE)
  maxParticipants Int        @default(4)
  currentCount    Int        @default(0)

  /// "PUBLIC" | "INVITE_ONLY"
  visibility     String        @default("PUBLIC")
  joinPriceCents Int           @default(0)
  status         BookingStatus @default(PENDING)

  /// A host can convert their own booking into an open-play session. The
  /// booking anchors the court and the capacity; the session layers
  /// matchmaking on top. Nullable because a session can also be created
  /// directly by the venue.
  linkedBookingId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resource      Resource?            @relation(fields: [resourceId], references: [id], onDelete: Cascade)
  linkedBooking Booking?             @relation("SessionBooking", fields: [linkedBookingId], references: [id])
  participants  SessionParticipant[]
  messages      SessionChatMessage[]

  @@index([tenantId, sport, startTs])
  @@index([tenantId, status])
  @@index([resourceId])
  @@index([hostUserId])
  @@map("open_play_session")
}

model SessionParticipant {
  sessionId String
  userId    String

  joinedAt    DateTime  @default(now())
  checkedInAt DateTime?

  session OpenPlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@id([sessionId, userId])
  @@index([userId])
  @@map("session_participant")
}

model SessionChatMessage {
  id        String @id @default(cuid())
  tenantId  String
  sessionId String

  senderUserId String
  /// Encrypted at rest + HTML-sanitised. User-authored text rendered to
  /// other users is an XSS surface; treat it as hostile.
  body         String

  createdAt DateTime @default(now())

  session OpenPlaySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([tenantId])
  @@index([senderUserId])
  @@map("session_chat_message")
}

/// GLOBAL — no tenantId. Skill follows the PLAYER, not the club.
///
/// A player's Glicko-2 rating earned at one venue must carry to the next,
/// otherwise matchmaking at a new club starts from zero and pairs a
/// competitive player against a beginner.
/// A player's rating for ONE sport, at ONE point in time.
///
/// Two engines live in this table, and their numbers are NOT comparable:
///
///   GLICKO2  (chess only) — mu ~1500, phi = rating deviation, sigma = volatility
///   OPENSKILL (everything else) — mu ~25, sigma = uncertainty, NO phi
///
/// `engine` is stored on every row rather than looked up from the registry,
/// because the registry can change and these rows cannot. A row written under
/// Glicko-2 must still be readable as Glicko-2 in a year, even if the sport has
/// since moved — otherwise the history renders as a cliff where a player's
/// rating apparently collapsed from 1500 to 25 overnight.
model SkillRatingHistory {
  id String @id @default(cuid())

  userId String
  sport  SportType

  /// Which engine produced these numbers. See the note above.
  engine RatingEngine

  mu    Decimal  @db.Decimal(8, 4)
  /// Glicko-2 only. NULL for openskill, which has no phi — and a 0 here would
  /// read as "perfectly certain", the exact opposite of what a missing value means.
  phi   Decimal? @db.Decimal(8, 4)
  sigma Decimal  @db.Decimal(8, 6)

  /// The conservative, displayable number (mu - 3σ, or mu - 2·phi). Denormalised
  /// so a leaderboard or a profile does not recompute it per row.
  displayRating Decimal @db.Decimal(8, 2)

  matchesPlayed Int      @default(0)
  computedAt    DateTime @default(now())

  @@index([userId, sport, computedAt])
  @@map("skill_rating_history")
}

enum RatingEngine {
  GLICKO2
  OPENSKILL
}

/// A recorded result. The thing ratings are computed FROM.
///
/// Kept separate from OpenPlaySession: not every match happens in a session
/// (a tournament round, a logged casual game), and a session can exist without
/// anyone reporting who won.
model MatchResultRecord {
  id       String  @id @default(cuid())
  tenantId String?

  sport     SportType
  sessionId String?

  /// [[userId, ...], [userId, ...]] — teams, ordered BEST-FIRST.
  teamsJson Json
  /// Lower is better; equal values are a draw.
  ranksJson Json

  /// IDEMPOTENCY. A result reported twice must not rate the match twice —
  /// ratings would move as if it had been played twice, which is the same class
  /// of bug as double-awarding XP, and far harder to undo because a rating
  /// update is not reversible by subtraction.
  dedupeKey String @unique

  reportedByUserId String?
  recordedAt       DateTime @default(now())

  participants MatchParticipant[]

  @@index([tenantId, sport, recordedAt])
  @@index([sessionId])
  @@map("match_result")
}

enum MatchOutcome {
  WIN
  LOSS
  DRAW
}

/// One player's participation in one match.
///
/// `teamsJson` on MatchResultRecord holds the SHAPE of the match. This holds the
/// part we need to QUERY: "what is my record?".
///
/// Deriving that from the JSON instead means fetching every recent match and
/// scanning it in JavaScript for the player's id — which is not merely slow, it
/// is WRONG: any bound on that fetch (and there must be one) silently truncates
/// a player's history to whichever matches happened to be in the window. A
/// player whose games are older than the cut-off would be told they have no
/// record.
///
/// The outcome is computed ONCE, at record time, from the ranks. A DRAW is
/// "somebody shares my rank", not "I came first" — conflating them inflates the
/// win rate of every player in a sport where draws are common.
model MatchParticipant {
  id      String @id @default(cuid())
  matchId String

  userId    String
  sport     SportType
  teamIndex Int
  rank      Int
  outcome   MatchOutcome

  recordedAt DateTime @default(now())

  match MatchResultRecord @relation(fields: [matchId], references: [id], onDelete: Cascade)

  /// A player appears in a match exactly once. The use case refuses a player on
  /// both sides; this is the backstop.
  @@unique([matchId, userId])
  /// The dashboard's query, exactly: one player, one sport, most recent first.
  @@index([userId, sport, recordedAt])
  @@map("match_participant")
}
