/// The player's standing AT a venue. Tenant-scoped on purpose — no-show count
/// is the club's business, not the player's global identity.
///
/// Credit does NOT live here. It lives in [CreditLedgerEntry], which is
/// append-only. A mutable `creditBalanceCents` column on this model was
/// removed in P16: a balance you can UPDATE cannot be reconstructed or
/// disputed, and two wallets in one codebase means someone eventually reads
/// the wrong one.
model PlayerVenueRelationship {
  id       String @id @default(cuid())
  tenantId String

  playerUserId String

  tags         String[]
  noShowCount  Int       @default(0)
  lastPlayedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, playerUserId])
  @@index([tenantId])
  @@index([playerUserId])
  @@map("player_venue_relationship")
}

model Membership {
  id       String @id @default(cuid())
  tenantId String

  playerUserId String
  level        String
  priceCents   Int
  currency     String           @default("EUR")
  startsAt     DateTime
  endsAt       DateTime
  autoRenew    Boolean          @default(false)
  status       MembershipStatus @default(ACTIVE)

  /// Set when the membership is billed through Stripe Billing rather than sold
  /// as a one-off. Unique: two memberships pointing at one subscription would
  /// both flip to ACTIVE on a single `invoice.paid`.
  stripeSubscriptionId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, playerUserId, level])
  @@index([tenantId, status])
  @@index([playerUserId])
  @@index([endsAt])
  @@map("membership")
}

model SeasonPass {
  id       String @id @default(cuid())
  tenantId String

  playerUserId  String
  name          String
  totalSessions Int
  usedSessions  Int      @default(0)
  priceCents    Int
  currency      String   @default("EUR")
  validFrom     DateTime
  validUntil    DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([playerUserId])
  @@index([validUntil])
  @@map("season_pass")
}
