model Venue {
  id       String @id @default(cuid())
  tenantId String

  slug        String
  name        String
  /// Encrypted at rest + HTML-sanitised on write.
  description String?

  addressLine String
  city        String
  country     String  @default("BG")
  lat         Decimal @db.Decimal(10, 7)
  lng         Decimal @db.Decimal(10, 7)

  /// PostGIS geography, kept in sync with lat/lng by a database trigger.
  ///
  /// Declared as `Unsupported` so PRISMA KNOWS IT EXISTS. Without this, the
  /// next `migrate diff` compares the live database to the schema, sees a
  /// column it cannot model, and generates `DROP COLUMN "geog"` — silently
  /// deleting the entire geo feature in a migration for something unrelated.
  /// That is not hypothetical: the P15 messaging migration did exactly that.
  geog     Unsupported("geography(Point, 4326)")?
  timezone String                                 @default("Europe/Sofia")
  phone    String?
  email    String

  openingHoursJson Json     @default("{}")
  amenityIds       String[]
  coverPhotoUrl    String?

  /// Drives the refund calculation on cancellation. Stored per venue so a
  /// club can set its own terms without a code change.
  cancellationPolicyJson Json @default("{\"fullRefundBeforeHours\":24,\"halfRefundBeforeHours\":12}")

  status      TenantStatus @default(ACTIVE)
  /// Denormalised from Review. Recomputed on write — a venue list renders
  /// hundreds of cards, and an AVG() per card is a guaranteed N+1.
  avgRating   Decimal      @default(0) @db.Decimal(2, 1)
  reviewCount Int          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resources Resource[]
  amenities VenueAmenity[]
  photos    VenuePhoto[]
  reviews   Review[]

  @@unique([tenantId, slug])
  @@index([tenantId, slug])
  @@index([city, country])
  @@index([tenantId, status])
  @@index([city, country, status])
  // The GiST index behind every "venues near me" query. Declared HERE — not
  // only in SQL — because `migrate diff` compares the live database to this
  // schema, and anything it cannot see looks like drift to be removed. It
  // proposed `DROP INDEX "venue_geog_idx"` in four separate unrelated
  // migrations before this line existed.
  @@index([geog], map: "venue_geog_idx", type: Gist)
  @@map("venue")
}

/// Formerly `Court`.
///
/// The MVP called everything a court, which stopped being true the moment a
/// chess table, an e-sports lobby and a running route had to be bookable.
///
/// The PHYSICAL TABLE is still `court` (see @@map). Renaming the table AND
/// rewriting every FK in one migration is how you lose the EXCLUDE constraint
/// that makes double-booking impossible — so the table rename is a separate,
/// later migration. This one only renames columns.
model Resource {
  id       String @id @default(cuid())
  tenantId String
  venueId  String

  name         String
  sport        SportType
  resourceType ResourceType @default(COURT)
  surface      CourtSurface
  isIndoor     Boolean      @default(false)
  capacity     Int          @default(4)
  status       TenantStatus @default(ACTIVE)

  /// Family-specific shape the relational model should not carry:
  /// field dimensions, board count, lobby game titles, route GPX ref +
  /// distance + elevation. Querying across these is not a use case; reading
  /// them as a unit is.
  metadataJson Json @default("{}")

  basePriceCents Int
  currency       String @default("EUR")

  minBookingMinutes Int @default(60)
  maxBookingMinutes Int @default(180)
  slotStepMinutes   Int @default(30)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue         Venue                  @relation(fields: [venueId], references: [id], onDelete: Cascade)
  availability  ResourceAvailability[]
  pricingRules  PricingRule[]
  bookings      Booking[]
  sessions      OpenPlaySession[]
  coachBookings CoachBooking[]

  @@index([tenantId, venueId, sport])
  @@index([tenantId, status])
  @@index([tenantId, venueId, sport, status])
  @@index([tenantId, resourceType])
  @@index([venueId])
  @@map("court")
}

model ResourceAvailability {
  id         String @id @default(cuid())
  tenantId   String
  resourceId String

  /// 0 = Sunday … 6 = Saturday.
  dayOfWeek Int
  openTime  DateTime @db.Time(0)
  closeTime DateTime @db.Time(0)

  effectiveFrom DateTime?
  effectiveTo   DateTime?
  /// A one-off override for a single date (holiday, maintenance).
  exceptionDate DateTime? @db.Date

  createdAt DateTime @default(now())

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([resourceId, dayOfWeek])
  @@index([tenantId])
  @@map("court_availability")
}

model PricingRule {
  id         String @id @default(cuid())
  tenantId   String
  resourceId String

  name     String
  /// Higher wins. The engine sorts descending and takes the first match.
  priority Int    @default(100)

  /// { dayOfWeek?: number[], timeRange?: {from,to}, playerTags?: string[],
  ///   membershipLevel?: string }
  conditionsJson Json @default("{}")

  multiplier      Decimal? @db.Decimal(4, 2)
  fixedPriceCents Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@index([tenantId, resourceId, priority])
  @@map("pricing_rule")
}

model VenueAmenity {
  id       String @id @default(cuid())
  tenantId String
  venueId  String

  code  String
  label String

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, code])
  @@index([tenantId])
  @@index([venueId])
  @@map("venue_amenity")
}

model VenuePhoto {
  id       String @id @default(cuid())
  tenantId String
  venueId  String

  url      String
  alt      String?
  position Int     @default(0)

  createdAt DateTime @default(now())

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([venueId, position])
  @@map("venue_photo")
}

model Review {
  id       String @id @default(cuid())
  tenantId String
  venueId  String

  authorUserId String
  rating       Int
  /// Encrypted at rest + sanitised — free text a stranger will read.
  body         String?

  /// PROOF OF VISIT. A review must point at a booking the author actually
  /// completed. Without this, the review section is an open comment box: a
  /// rival club can leave one-stars, and a venue can leave itself five-stars,
  /// without either ever setting foot on the court.
  ///
  /// Unique: one review per booking. Otherwise a single visit is worth as many
  /// reviews as the author has patience for.
  bookingId String? @unique

  /// Nothing is visible until it has been through moderation. The default is
  /// PENDING_REVIEW, not PUBLISHED — a row created by a code path that forgets
  /// to moderate is INVISIBLE, rather than unmoderated-and-live.
  status ReviewStatus @default(PENDING_REVIEW)

  /// What the classifier saw. Kept so a human reviewing the case can judge the
  /// machine as well as the text.
  moderationScoresJson Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  venue Venue @relation(fields: [venueId], references: [id], onDelete: Cascade)

  @@unique([venueId, authorUserId])
  @@index([tenantId])
  @@index([venueId, status, createdAt])
  @@index([venueId, createdAt])
  @@index([authorUserId])
  @@map("review")
}
